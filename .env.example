# Copiá a `.env.local` en la raíz: `cp .env.example .env.local` (PowerShell: `Copy-Item .env.example .env.local`)
#
# Este archivo documenta variables útiles para Docker / scripts en la raíz.
# Para `bun run dev` y `bun run convex:dev` hacé también `apps/demo/.env.local`
# (ver `apps/demo/.env.example`).

# ----- Convex self-hosted (docker compose) -----
# Tras `docker compose up -d backend`: `docker compose exec -T backend ./generate_admin_key.sh`
# Pegá la línea completa `notchat-local|...`.
CONVEX_SELF_HOSTED_URL=http://localhost:3210
# No pongas CONVEX_DEPLOY_KEY acá si usás la CLI hacia self-hosted: puede forzar Convex Cloud.
# Para el sync usá `apps/demo/scripts/sync-set-config.local.json` → `deployKey`.
CONVEX_SELF_HOSTED_ADMIN_KEY=notchat-local|PASTE_ADMIN_KEY_HERE

# Debe coincidir con INSTANCE_SECRET del backend (ver `docker-compose.yml`). Cambiá en prod.
CONVEX_INSTANCE_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ----- Destino: DuckDB local (ruta dentro del contenedor del backend) -----
# `docker-compose.yml` monta `./data/duckdb` del host en `/data` en el contenedor.
DUCKDB_PATH=/data/local.duckdb

# ----- Destino: MotherDuck (opcional) -----
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB_URL=

# ----- Next.js (solo si corrés Next desde la raíz con tooling que lea este archivo) -----
# El demo suele usar `apps/demo/.env.local` → `NEXT_PUBLIC_CONVEX_URL`.
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210
