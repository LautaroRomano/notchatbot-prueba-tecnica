# ----- Convex self-hosted (docker compose) -----
# URL del backend Convex local. La generación de admin/deploy keys se hace
# con: `docker compose exec backend ./generate_admin_key.sh` (o equivalente
# del repo convex-backend). Pegá la deploy key acá.
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=
CONVEX_DEPLOY_KEY=

# Secret del backend self-hosted. Tiene que coincidir con INSTANCE_SECRET
# del docker-compose.yml. Cambialo a un valor random para producción.
CONVEX_INSTANCE_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ----- Destino: DuckDB local (default) -----
DUCKDB_PATH=./local.duckdb

# ----- Destino: MotherDuck (opcional, para evaluación final) -----
# Si están seteadas, el componente las prefiere sobre DUCKDB_PATH.
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB_URL=

# ----- Next.js -----
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
