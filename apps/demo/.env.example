# Leído por `convex dev` / Next al trabajar en apps/demo (no usa .env.local de la raíz).
# Backend Docker: `docker compose up -d backend` + `docker compose exec -T backend ./generate_admin_key.sh`
CONVEX_SELF_HOSTED_URL=http://localhost:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=notchat-local|PASTE_ADMIN_KEY_HERE

# Cliente en el navegador — en Windows + Docker usá localhost (no 127.0.0.1).
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://localhost:3211

# Con self-hosted no definas CONVEX_DEPLOYMENT (la CLI falla si convive con CONVEX_SELF_HOSTED_*).
